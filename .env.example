# Netrek Containerized - Environment Configuration
# Copy to .env and customize as needed

# X11 display for macOS XQuartz
DISPLAY=host.docker.internal:0

# PulseAudio for sound forwarding (macOS)
PULSE_SERVER=tcp:host.docker.internal:4713

# Server TCP port (mapped to container 2592)
SERVER_PORT=2692

# UDP port range base (mapped from container 2593+)
UDP_PORT_BASE=2693
